# GCP Product C (AI Q&A) — 環境變數範本
# 機密欄位請寫入 GCP Secret Manager（deploy/fetch_secrets.sh 會組合成 /run/secrets/.env）
# 非機密路徑由 docker-compose.gcp.yml 的 environment 區塊覆寫，此處僅供對照。

# --- Secret Manager（建議單一 secret：streamer-toolbox-env）---
# TWITCH_CHANNEL=your_channel
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# TWITCH_BOT_REFRESH_TOKEN=
# TWITCH_BOT_ID=
# TWITCH_CHANNEL_REFRESH_TOKEN=          # 雙帳號 EventSub 時需要
# TWITCH_BROADCASTER_ID=
# TWITCH_SINGLE_ACCOUNT=false
# GOOGLE_AI_API_KEY=
# GOOGLE_AI_MODEL=gemini-2.5-flash

# --- Compose 已注入（通常不需寫入 secret）---
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
# STREAM_DB_PATH=/data/stream_text.db
# LLM_CHROMA_DIR=/data/chroma
# STREAMER_CONFIG_DIR=/config
# LLM_KNOWLEDGE_PATH=/config/knowledge

# --- 產品 C 建議設定 ---
STREAM_EXCHANGE=stream_helper
RECORD_MODE=both
LLM_BACKEND=gemini
LLM_KNOWLEDGE_BACKEND=chroma
LLM_TRIGGER_PREFIXES=!ask
QA_MEMORY_MODE=structured
LLM_MEMORY_FROM_DB=true
TWITCH_STREAM_POLL_SECONDS=60
STT_MODEL_SIZE=medium
STT_DEVICE=auto
STT_CPU_THREADS=4
LLM_GAME_INFO_ENABLED=true
LLM_STARTUP_ANNOUNCEMENT=true
