# RabbitMQ（Phase 01 共用）
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/
STREAM_EXCHANGE=stream_helper

# 外部設定目錄（方案 A）；小工具與主程式共用
# Windows: %USERPROFILE%/streamer-config  |  Linux/GCP: ~/streamer-config 或 /config
STREAMER_CONFIG_DIR=%USERPROFILE%/streamer-config
# 以下可留空，自動指向 STREAMER_CONFIG_DIR 內對應檔案
# BOT_RESPONSES_PATH=
# BOT_REDEMPTIONS_PATH=
# LLM_SUBSCRIBER_CONFIG=
# LLM_KNOWLEDGE_PATH=
# VISUAL_CONFIG_PATH=

# ingress-ttv-read / ingress-twitch-eventsub / ingress-twitch-stream
TWITCH_CHANNEL=your_channel
# ingress-twitch-stream：GQL 輪詢直播 metadata（標題、分類、時長），建議 ≥30 秒
TWITCH_STREAM_POLL_SECONDS=60

# identity-oauth + ingress-twitch-eventsub + twitch-connector
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Twitch Developer Console 應用 OAuth Redirect URI 須包含此值（預設本機 callback）
TWITCH_REDIRECT_URI=http://localhost:17563
# 雙帳號（對齊 twitch_api；未設時 fallback 至 TWITCH_REFRESH_TOKEN）
TWITCH_CHANNEL_REFRESH_TOKEN=
TWITCH_BOT_REFRESH_TOKEN=
TWITCH_BROADCASTER_ID=
TWITCH_BOT_ID=
# 可選：IRC 缺 author_id 時以 login 比對 BOT 觸發
TWITCH_BOT_LOGIN=
TWITCH_BROADCASTER_TYPE=affiliate
# 過渡：單組 token（identity-oauth v0.1 現況）
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=
# true 時 bot 鏡射 channel（對齊 twitch_api single_account_mode）
TWITCH_SINGLE_ACCOUNT=false
TWITCH_DEFAULT_SENDER=bot
# 可選：靜態 access（通常留空，由 refresh 自動取得）
TWITCH_CHANNEL_ACCESS_TOKEN=
TWITCH_BOT_ACCESS_TOKEN=

# ingress-discord（Bot 須啟用 Message Content Intent）
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_CHANNEL_ID=your_channel_snowflake_id

# ingress-yt-read（頻道 handle、@ 網址或直播 watch?v=；對齊 hello_streamer 的 youtube.name）
YT_CHANNEL=skymiku39

# sub-io-log
IO_LOG_PATH=logs/chat_io.jsonl
IO_LOG_CONSOLE=true

# L1 記錄層 / L2 記憶層
# chat | stt | both（聊天 + 實況語音 STT）
RECORD_MODE=both
STREAM_DB_PATH=data/stream_text.db
# 跨 process 冪等去重（ingress / sub-llm / twitch-connector 共用；預設同 STREAM_DB_PATH）
# EVENT_DEDUP_DB_PATH=data/stream_text.db
STREAM_SESSION_ID=
MEMORY_INTERVAL_MINUTES=30
# 常駐 worker 監聽 memory.summarize.request，收到後立即摘要一次
MEMORY_TRIGGER_LISTEN=true
# 摘要完成後 publish memory.summary.ready（供 board / 其他 Sub 訂閱）
MEMORY_PUBLISH_READY=true

# sub-memory-board（本機瀏覽摘要）
MEMORY_BOARD_HOST=127.0.0.1
MEMORY_BOARD_PORT=8765
MEMORY_BOARD_MQ=true
MEMORY_LLM_BACKEND=gemini
# L2 定時摘要模型；未設時 gemini 預設 gemini-2.5-flash（免費層友善）。
# Pro 每日僅 50 RPD 且配額池獨立，建議僅用於收台/手動深度摘要（見 MEMORY_DEEP_MODEL）。
MEMORY_LLM_MODEL=gemini-2.5-flash
# 收台/手動深度摘要模型（depth=pro 觸發時使用；留空＝深度觸發退回一般 Flash）。
# Pro 每日 50 RPD，配額池獨立於 Flash，適合收台一次性高品質回顧。
# 手動觸發：uv run python -m app.workers --trigger --deep
MEMORY_DEEP_MODEL=gemini-2.5-pro
# both 模式：兩邊皆有資料時合併 chat/stt 為單次 LLM 呼叫（省一半 memory RPD）
MEMORY_MERGE_SUMMARY=true
# 可選：MEMORY_LLM_API_KEY、MEMORY_LLM_API_BASE（未設則沿用 GOOGLE_AI_API_KEY / LLM_API_BASE）
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash

# ingress-twitch-audio / ingress-local-audio（STT，faster-whisper）
# tiny/base/small/medium/large-v2/large-v3；CPU 建議 medium，有 NVIDIA GPU 可試 large-v3
STT_MODEL_SIZE=medium
STT_CHUNK_SECONDS=4
STT_LANGUAGE=zh
STT_DEVICE=auto
STT_COMPUTE_TYPE=auto
STT_CPU_THREADS=4
STT_RMS_GATE=0.004
STT_FILTER_HALLUCINATIONS=true
# chunk 不像語音（FFT）時才套用幻覺過濾
STT_HALLUCINATION_RMS_GATE=0.02
STT_HALLUCINATION_SPEECH_BAND_MIN=0.25
STT_HALLUCINATION_SPECTRAL_FLATNESS_MAX=0.35
STT_VAD_FILTER=false
STT_CONDITION_ON_PREVIOUS_TEXT=true
STT_NO_SPEECH_THRESHOLD=0.85
STT_LOG_PROB_THRESHOLD=-1.0
STT_COMPRESSION_RATIO_THRESHOLD=2.4
STT_BEAM_SIZE=1
# 引導 Whisper 辨識常用詞（逗號或空格分隔）；可留空
STT_INITIAL_PROMPT=
# 將上一段 STT 文字帶入下一 chunk 的 initial_prompt
STT_CARRY_PROMPT=true
# ingress 串流前輕量降噪（高通 + 頻譜門檻）
STT_DENOISE=true
STT_DENOISE_HP_HZ=80
STT_DENOISE_GATE_RATIO=0.08

# ingress-twitch-audio 可選：瀏覽器 auth-token（非 Helix token，勿與 TWITCH_ACCESS_TOKEN 混用）
TWITCH_STREAMLINK_AUTH_TOKEN=

# ingress-local-audio（本機麥克風 STT，與 ingress-twitch-audio 二選一）
# 裝置索引（整數）或名稱子字串；留空使用系統預設麥克風
LOCAL_AUDIO_DEVICE=

# ============================================================
# 免費層 Gemini 建議設定（最大化免費額度；詳見 docs/deployment-gcp.md §6.1）
#   LLM_BACKEND=hybrid              # lite agent 路由，命中短期記憶不打主模型
#   LLM_ASK_MODEL=gemini-2.5-flash  # 主回答用 Flash（RPD 約 1500）
#   LLM_AGENT_MODEL=gemini-2.0-flash-lite
#   LLM_WEB_SEARCH=auto             # 僅即時事實類問題才 grounding
#   QA_MEMORY_MODE=batch            # 不在每次 !ask 多打結構化 LLM
#   MEMORY_LLM_MODEL=gemini-2.5-flash   # 日常摘要 Flash；Pro 留給收台
#   MEMORY_INTERVAL_MINUTES=60      # both 模式降頻，摘要次數減半
# ============================================================

# sub-llm
LLM_TRIGGER_PREFIXES=!ask
LLM_CONTEXT_WINDOW_MINUTES=15
# sub-llm 略過低信心 stt.segment（0=關閉；0.25 約略過 avg_logprob<-1.4 的片段）
STT_MIN_CONFIDENCE=0
LLM_BOT_REPLY_WINDOW_MINUTES=30
LLM_BOT_REPLY_MAX_PAIRS=5
LLM_MAX_REPLY_LENGTH=200
LLM_SUBSCRIBER_CONFIG=config/llm_subscriber.json
# LLM 問答後端（技術 ID → 產品名稱見 sub_llm/llm_backends.py）
# gemini     = Gemini 直連（gemini-direct）— 單段式問答，可選 Google Search
# hybrid     = Hybrid Agent（hybrid-agent）— 小 Agent 路由 + 主 Gemini；POC 建議
LLM_BACKEND=template
# sub-llm 預設從 L2 summaries 讀記憶；設 false 則僅用 LLM_KNOWLEDGE_PATH 檔案
LLM_MEMORY_FROM_DB=true
# Chroma 摘要「同步視窗」：索引進向量庫的摘要筆數，與下方 query top-K 解耦。
# 視窗放大可讓早段記憶仍被語意召回；查詢仍只取最相關的 top-K。
# 優先讀此值，未設時回退舊的 LLM_MEMORY_SUMMARY_LIMIT，皆未設時預設 50。
LLM_MEMORY_SYNC_LIMIT=50
# （已淘汰名稱，保留向後相容；新設定請用 LLM_MEMORY_SYNC_LIMIT）
# LLM_MEMORY_SUMMARY_LIMIT=10
# 知識庫後端（必填 chroma）：靜態知識 + L2 摘要皆以 Chroma 向量 RAG 檢索
LLM_KNOWLEDGE_BACKEND=chroma
LLM_CHROMA_DIR=data/chroma
LLM_CHROMA_QUERY_LIMIT=3
# query 階段取回的最相關片段數（top-K），與上方同步視窗無關
LLM_CHROMA_MEMORY_QUERY_LIMIT=5
# 向量 embedding 後端：留空＝Chroma 預設（all-MiniLM-L6-v2，英文偏向）。
# 切換 embedding 後既有向量空間不相容，需刪除 data/chroma 重新索引。
#
# 多語系方案一（推薦，安裝輕量）：用既有 Gemini 金鑰呼叫 text-embedding-004，
#   繁中召回佳，但每次查詢／索引需網路（離線不可用）。
#   LLM_EMBEDDING_BACKEND=gemini
#   # 可選：LLM_EMBEDDING_MODEL=text-embedding-004
#
# 多語系方案二（離線、無 API 成本，但需 sentence-transformers/torch 數 GB）：
#   LLM_EMBEDDING_BACKEND=sentence-transformers
#   LLM_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# Gemini sub-llm 可共用 GOOGLE_AI_*；或另設 LLM_API_KEY / LLM_MODEL
# Bot 問答長期記憶：none（原本）| structured（同次評分）| batch（多次 L2 摘要）
QA_MEMORY_MODE=structured
LLM_QA_MEMORY_MIN_VALUE=3
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
# 即時 !ask 主模型（高頻、低延遲）；未設時沿用 LLM_MODEL / GOOGLE_AI_MODEL
LLM_ASK_MODEL=
LLM_MODEL=gpt-4o-mini
# 留空則使用 app 內建預設（自然語氣、上下文不足時仍用通識／知識庫／Google 搜尋作答）
LLM_SYSTEM_PROMPT=
# Gemini 後端 Google Search grounding：false=永不 | true=每題 | auto=僅即時事實類問題
# 免費層 2.x grounding 每月約 500 query（按 AI 實際搜尋數扣），建議 auto。預設 false。
LLM_WEB_SEARCH=false
# LLM 呼叫韌性：429/5xx 與網路錯誤的指數退避重試
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_BASE_DELAY_SEC=0.5
LLM_RETRY_MAX_DELAY_SEC=8.0
# 斷路器：連續失敗達門檻後冷卻期內直接回降級訊息，不再打爆故障端點
LLM_CIRCUIT_FAILURE_THRESHOLD=5
LLM_CIRCUIT_RESET_SEC=30
# 結構化決策 log：true 時 ask_decision 等事件以 JSON 輸出，便於彙整／監控
LLM_LOG_JSON=false
# true（預設）時允許 RAG 不足時用模型自身知識；false 則僅限提供的上下文與知識庫
LLM_GENERAL_KNOWLEDGE=true
LLM_KNOWLEDGE_PATH=data/knowledge
# 程序啟動時是否發問候／降級宣告至 chat.reply（預設 true；僅 --stack llm）
LLM_STARTUP_ANNOUNCEMENT=true
# --stack status：收到 stream.metadata 後是否發布目前直播狀態至聊天室（預設 true）
LIVE_STATUS_ANNOUNCEMENT=true
# 直播中注入 IGDB 遊戲評分／簡介（沿用 TWITCH_CLIENT_ID/SECRET，預設 true）
LLM_GAME_INFO_ENABLED=true
LLM_GAME_INFO_CACHE_TTL_SECONDS=3600
# 本場回顧 enrichment：觀眾問及今天／本場進度時，額外注入 L2 時序摘要 + 未摘要 STT
LLM_SESSION_RECAP_ENABLED=true
LLM_SESSION_RECAP_SUMMARY_LIMIT=30
LLM_SESSION_RECAP_RAW_STT_LIMIT=80
LLM_SESSION_RECAP_MAX_CHARS=8000

# Hybrid Agent 版（LLM_BACKEND=hybrid；與 T4 Hybrid STT 無關）
# 將上方 LLM_BACKEND 改為 hybrid；sub-llm 會自動 setdefault（.env 已設者不被覆寫）
# LLM_BACKEND=hybrid
# 前置路由（超低 token，僅 hybrid 使用）
LLM_AGENT_MODEL=gemini-2.0-flash-lite
# 即時問答主模型（hybrid 升級路徑與 gemini 直連共用 LLM_ASK_MODEL）
# LLM_ASK_MODEL=gemini-2.5-flash
# --- 自動啟用（不消耗 LLM token：檢索／規則／IGDB REST）---
# LLM_GAME_INFO_ENABLED=true
# LLM_SESSION_RECAP_ENABLED=true
# LLM_MEMORY_FROM_DB=true
# LLM_SHORT_TERM_RAG_ENABLED=true
# LLM_INJECTION_GUARD=true
# LLM_KNOWLEDGE_PATH=data/knowledge
# --- 低 token 長期記憶（batch：寫入 SQLite 無額外 ask token；L2 摘要靠 memory worker 定時）---
# QA_MEMORY_MODE=batch
# --- 自動關閉（會多打 LLM／grounding API）---
# LLM_WEB_SEARCH=false
# LLM_STARTUP_ANNOUNCEMENT=false
# 若要產生 L2 聊天／STT 摘要，另開：uv run python -m app.workers --llm-backend gemini
# 流程管控與短期 RAG 參數（皆不消耗 token）
LLM_SHORT_TERM_RAG_MINUTES=30
LLM_SHORT_TERM_RAG_MAX_PAIRS=20
LLM_FLOW_DEDUP_WINDOW_SECONDS=120
LLM_FLOW_DEDUP_CANNED_REPLY=這題剛剛回答過囉，換個問題試試～
LLM_FLOW_DEDUP_HARD_CANNED_REPLY=問太快了啦，等一下再問～

# sub-character-face（VTS WebSocket）
CHARACTER_FACE_DRIVER=vts-stub
VTS_WS_URL=ws://localhost:8001
VTS_PLUGIN_NAME=Streamer Toolbox
VTS_PLUGIN_DEVELOPER=streamer-toolbox
VTS_AUTH_TOKEN=

# sub-character-stage（OBS WebSocket）
STAGE_DRIVER=log
OBS_WS_HOST=localhost
OBS_WS_PORT=4455
OBS_WS_PASSWORD=
OBS_SCENE_NAME=
OBS_MEDIA_SOURCE=CharacterAudio

# voice-clone（離線語音克隆 CLI；可選，不接入 app/MQ）
# 詳見 packages/voice-clone/README.md
VOICE_CLONE_ROOT=./packages/voice-clone
OMNIVOICE_ROOT=./packages/voice-clone/vendor/OmniVoice
VOICE_CLONE_MODEL=k2-fsa/OmniVoice
VOICE_CLONE_LANGUAGE=Chinese
VOICE_CLONE_OFFLINE=1
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
VOICE_CLONE_DEVICE=cuda:0
VOICE_CLONE_NUM_STEP=16
VOICE_CLONE_DENOISE=1
VOICE_CLONE_TRIM_SILENCE=1
