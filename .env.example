# RabbitMQ（Phase 01 共用）
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/
STREAM_EXCHANGE=stream_helper

# ingress-ttv-read / ingress-twitch-eventsub / ingress-twitch-stream
TWITCH_CHANNEL=your_channel
# ingress-twitch-stream：GQL 輪詢直播 metadata（標題、分類、時長），建議 ≥30 秒
TWITCH_STREAM_POLL_SECONDS=60

# identity-oauth + ingress-twitch-eventsub + twitch-connector
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# 雙帳號（對齊 twitch_api；未設時 fallback 至 TWITCH_REFRESH_TOKEN）
TWITCH_CHANNEL_REFRESH_TOKEN=
TWITCH_BOT_REFRESH_TOKEN=
TWITCH_BROADCASTER_ID=
TWITCH_BOT_ID=
TWITCH_BROADCASTER_TYPE=affiliate
# 過渡：單組 token（identity-oauth v0.1 現況）
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=
# true 時 bot 鏡射 channel（對齊 twitch_api single_account_mode）
TWITCH_SINGLE_ACCOUNT=false
TWITCH_DEFAULT_SENDER=bot
# 可選：靜態 access（通常留空，由 refresh 自動取得）
TWITCH_CHANNEL_ACCESS_TOKEN=
TWITCH_BOT_ACCESS_TOKEN=

# ingress-discord（Bot 須啟用 Message Content Intent）
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_CHANNEL_ID=your_channel_snowflake_id

# ingress-yt-read（直播網址或 11 碼影片 ID）
YT_CHANNEL=https://www.youtube.com/watch?v=your_live_video_id

# sub-io-log
IO_LOG_PATH=logs/chat_io.jsonl
IO_LOG_CONSOLE=true

# L1 記錄層 / L2 記憶層
# chat | stt | both（聊天 + 實況語音 STT）
RECORD_MODE=both
STREAM_DB_PATH=data/stream_text.db
# 跨 process 冪等去重（ingress / sub-llm / twitch-connector 共用；預設同 STREAM_DB_PATH）
# EVENT_DEDUP_DB_PATH=data/stream_text.db
STREAM_SESSION_ID=
MEMORY_INTERVAL_MINUTES=30
# 常駐 worker 監聽 memory.summarize.request，收到後立即摘要一次
MEMORY_TRIGGER_LISTEN=true
# 摘要完成後 publish memory.summary.ready（供 board / 其他 Sub 訂閱）
MEMORY_PUBLISH_READY=true

# sub-memory-board（本機瀏覽摘要）
MEMORY_BOARD_HOST=127.0.0.1
MEMORY_BOARD_PORT=8765
MEMORY_BOARD_MQ=true
MEMORY_LLM_BACKEND=gemini
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash

# ingress-twitch-audio（STT，faster-whisper）
# tiny/base/small/medium/large-v2/large-v3；CPU 建議 medium，有 NVIDIA GPU 可試 large-v3
STT_MODEL_SIZE=medium
STT_CHUNK_SECONDS=5
STT_LANGUAGE=zh
STT_DEVICE=auto
STT_COMPUTE_TYPE=auto
STT_CPU_THREADS=4
STT_RMS_GATE=0.01
STT_FILTER_HALLUCINATIONS=true
STT_VAD_FILTER=true

# ingress-twitch-audio 可選：瀏覽器 auth-token（非 Helix token，勿與 TWITCH_ACCESS_TOKEN 混用）
TWITCH_STREAMLINK_AUTH_TOKEN=

# ingress-local-audio（本機麥克風 STT，與 ingress-twitch-audio 二選一）
# 裝置索引（整數）或名稱子字串；留空使用系統預設麥克風
LOCAL_AUDIO_DEVICE=

# sub-llm
LLM_TRIGGER_PREFIXES=!ask
LLM_CONTEXT_WINDOW_MINUTES=15
LLM_BOT_REPLY_WINDOW_MINUTES=30
LLM_MAX_REPLY_LENGTH=500
LLM_SUBSCRIBER_CONFIG=config/llm_subscriber.json
LLM_BACKEND=template
# sub-llm 預設從 L2 summaries 讀記憶；設 false 則僅用 LLM_KNOWLEDGE_PATH 檔案
LLM_MEMORY_FROM_DB=true
LLM_MEMORY_SUMMARY_LIMIT=10
# 知識庫後端（必填 chroma）：靜態知識 + L2 摘要皆以 Chroma 向量 RAG 檢索
LLM_KNOWLEDGE_BACKEND=chroma
LLM_CHROMA_DIR=data/chroma
LLM_CHROMA_QUERY_LIMIT=3
LLM_CHROMA_MEMORY_QUERY_LIMIT=5
# Gemini sub-llm 可共用 GOOGLE_AI_*；或另設 LLM_API_KEY / LLM_MODEL
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_SYSTEM_PROMPT=你是直播助手，請簡短回答觀眾問題。資訊來源優先順序：直播狀態 > 近期逐字稿與聊天 > Bot 近期回覆 > 遊戲資料參考 > 知識庫摘要。若直播狀態已標示正在玩的遊戲，勿被早期摘要中「測試／模擬／開發工具」等過時描述覆蓋。Bot 近期回覆代表你剛才對觀眾說過的話，延續同一話題時應與之一致。若上述來源沒有相關資訊，可用你本身的常識補充。勿捏造與直播主、頻道相關的未提供事實。勿使用 Markdown（無粗體、標題、連結語法），以純文字短句回覆，適合 Twitch 聊天室。
# true（預設）時允許 RAG 不足時用模型自身知識；false 則僅限提供的上下文與知識庫
LLM_GENERAL_KNOWLEDGE=true
LLM_KNOWLEDGE_PATH=data/knowledge

# sub-character-face（VTS WebSocket）
CHARACTER_FACE_DRIVER=vts-stub
VTS_WS_URL=ws://localhost:8001
VTS_PLUGIN_NAME=Streamer Toolbox
VTS_PLUGIN_DEVELOPER=streamer-toolbox
VTS_AUTH_TOKEN=

# sub-character-stage（OBS WebSocket）
STAGE_DRIVER=log
OBS_WS_HOST=localhost
OBS_WS_PORT=4455
OBS_WS_PASSWORD=
OBS_SCENE_NAME=
OBS_MEDIA_SOURCE=CharacterAudio
